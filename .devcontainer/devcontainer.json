{
  "name": "Rust Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "mounts": [
    "source=rstutils-zsh-history,target=/commandhistory,type=volume"
  ],
  "forwardPorts": [],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "eamodio.gitlens"
      ]
    }
  },
  "postCreateCommand": "pre-commit install --install-hooks",
  "remoteUser": "vscode"
}
