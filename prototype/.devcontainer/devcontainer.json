{
  "name": "Python Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",
  "forwardPorts": [],
  "extensions": [
    "ms-python.python",
    "charliermarsh.ruff"
  ],
  "settings": {
    "python.defaultInterpreterPath": "/usr/local/bin/python"
  },
  "postCreateCommand": "uv install --no-cache-dir -r requirements.txt || true",
  "remoteUser": "vscode"
}
